# brightness keybindings
XF86MonBrightness{Up,Down}
	xbacklight {-inc,-dec} 10

# media keys
XF86Audio{Next,Prev,Play,Stop}
	mpc {next,prev,toggle,stop}
XF86AudioPlay
	playerctl play-pause
XF86AudioStop
	playerctl stop
XF86AudioNext
	playerctl next
XF86AudioPrev
	playerctl previous

# Volume {up,down,mute}
XF86Audio{RaiseVolume,LowerVolume,Mute}
	pactl set-sink-volume @DEFAULT_SINK@ {+10%,-10%,toggle}
XF86AudioMedia
	$TERMINAL -e ncmpcpp

# Recording
# Take screenshot
super + Print
	maim ~/Pictures/screenshots/pic-full-$(date '+%y%m%d-%H%M-%S').png
# Pick screenshot type
Print
	maimpick

shift + Print
        scrot ~/Pictures/screenshots/$(date --iso-8601='seconds').png -s -e 'xclip -selection c -t image/png < $f'

# Print: Record audio or video; Del: kill recording
super + shift + Print
	dmenurecord
super + Delete
	dmenurecord kill

# Pause audio
super + p
	mpc toggle
super + shift + p
  mpc pause; pauseallmpv
## MEDIA - Spotify
# AUR - playerctl
super + gbreve
    playerctl stop
super + udiaeresis
    playerctl play-pause
# Changes to next/previous tracks
super + {comma,period}
  playerctl {previous,next}
# Restart track
super + shift + less
	mpc seek 0%
# Seek foward in song
super + {_,shift +} bracketright
	mpc seek +{10,120}
# Seek backward in song
super + {_,shift +} bracketleft
	mpc seek -{10,120}
# Increase volume
super {_,shift +} + plus
	amixer sset Master {5,15}%+; pkill -RTMIN+10 $STATUSBAR
# Decrease volume
super {_,shift +} + minus
	amixer sset Master {5,15}%-; pkill -RTMIN+10 $STATUSBAR
super + shift + m
	amixer sset Master toggle; pkill -RTMIN+10 $STATUSBAR


XF86PowerOff
	prompt "Shutdown computer?" "sudo -A shutdown -h now"
XF86Calculator
	$TERMINAL -e bc
XF86Sleep
	prompt 'Hibernate computer?' 'sudo -A zzz'
XF86WWW
	$BROWSER
XF86DOS
	$TERMINAL
XF86ScreenSaver
	mpc pause; pauseallmpv; i3lock -e -f -c 1d2021; xset dpms force off
XF86TaskPane
	$TERMINAL -e htop
XF86Mail
	$TERMINAL -e neomutt
XF86Tools
	$FILE ~/

# Function keys
super + F1
	zathura ~/Documents/markdown-cheatsheet-online.pdf

# F2 restarts either dwm or i3 and is bound in each.

# Change display
super + F3
	displayselect

# Hibernate
super + F4
	prompt 'Hibernate computer?' 'sudo -A zzz -Z'

super + F5 is unbound.

super + F6

# toggle torrent daemon
super + F7
	td-toggle
# sync news
super + F8
	newsup
# Mount a USB drive or Android device
super + {F9,F10}
	{dmenumount,dmenuumount}
