#!/bin/sh

# dwm statusbar - show current date and time

while true; do

        date '+’ü│  %a. %d %b. ’ĆŚ   %R ' > /tmp/CurTime.tmp

        sleep 60s
done &

while true; do

	brightness=$(expr $(cat /sys/class/backlight/intel_backlight/brightness) / 242)
	volume=$(pamixer --get-volume-human)
	bat=$(acpi -b | awk '{ split($5,a,":"); print substr($3,0,2), $4, "["a[1]":"a[2]"]" }' | tr -d ',')
 	mem=$(free -h --kilo | awk '/^Mem:/ {print $3 "/" $2}')
	cpu=$(top -bn1 | grep "Cpu(s)" | sed "s/.*, *\([0-9.]*\)%* id.*/\1/" | awk '{print 100 - $1}' )
	temp=$(sensors|grep 'Core 0'|awk '{print $3}' )
	disk=$(df -h /dev/nvme0n1p4 | tail -1 | awk '{print $4}')
	time=$(< /tmp/CurTime.tmp)

	xsetroot -name "­¤×╝ ${brightness} ’®Š $volume  ’ēü  ${bat} ’ł│ $mem ’ćĆ $cpu%  ’ŗē $temp ’éĀ  $disk ’ģé $time ’īā "
        sleep 10s
done &
