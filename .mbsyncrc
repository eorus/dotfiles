# Global Channel configuration.
Create Both
Expunge Both
Remove Both
Sync All
SyncState *

################################
####### alperor@gmail.com ######
################################

# IMAP setup
IMAPAccount gmail
Host imap.gmail.com
User alperor@gmail.com
PassCmd "pass neomutt/alperor"
SSLType IMAPS
AuthMechs LOGIN

# Remote storage setup
IMAPStore gmail-remote
Account gmail

# Local storage setup
MaildirStore gmail-local
Path ~/Mail/gmail/
Inbox ~/Mail/gmail/Inbox

# Inbox
Channel gmail-inbox
Far :gmail-remote:
Near  :gmail-local:Inbox

# Sent
Channel gmail-sent
Far :gmail-remote:"[Gmail]/Sent Mail"
Near  :gmail-local:Sent

# Drafts
Channel gmail-drafts
Far :gmail-remote:"[Gmail]/Drafts"
Near  :gmail-local:Drafts

# Trash
Channel gmail-trash
Far :gmail-remote:"[Gmail]/Trash"
Near  :gmail-local:Trash

# Spam
Channel gmail-spam
Far :gmail-remote:"[Gmail]/Spam"
Near  :gmail-local:Spam

Group gmail
Channel gmail-Inbox
Channel gmail-Sent
Channel gmail-Drafts
Channel gmail-Trash
Channel gmail-Spam

# IMAP setup
IMAPAccount eorus
Host imap.dreamhost.com
User alper@eorus.com
PassCmd "pass neomutt/alper"
SSLType IMAPS
AuthMechs LOGIN
#CertificateFile ~/.cert/some.imap.server.pem #/etc/ssl/certs/ca-certificates.crt

IMAPStore eorus-remote
Account eorus

MaildirStore eorus-local
#SubFolders Legacy
Path ~/Mail/eorus/
Inbox ~/Mail/eorus/Inbox

# Channels and Groups
# (so that we can rename local directories and flatten the hierarchy)

# Inbox
Channel eorus-inbox
Far :eorus-remote:
Near  :eorus-local:Inbox

# Sent
Channel eorus-sent
Far :eorus-remote:"INBOX/Sent"
Near  :eorus-local:Sent

# Draft
Channel eorus-draft
Far :eorus-remote:"INBOX/Drafts"
Near  :eorus-local:Drafts

#Patterns *
#Create Both
#Expunge Both
#SyncState *

Group eorus
Channel eorus-Inbox
Channel eorus-Sent
Channel eorus-Drafts

# Gmail mailboxes:
# "All Mail"
# "Drafts"
# "Important"
# "Sent Mail"
# "Spam"
# "Starred"
# "Trash"
